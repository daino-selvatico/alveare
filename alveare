#!/usr/bin/env bash
#
# alveare — top-level command-line entry point for the Alveare NPU LLM runtime.
#
# An open-source LLM inference runtime for the AMD Ryzen AI (XDNA2) NPU on Linux.
#
# Subcommands:
#   setup            Print environment guidance and run lightweight preflight checks.
#   check            Run the NPU smoke test (wraps tools/check_npu.sh).
#   serve <model>    Start the OpenAI-compatible server for a model / weights dir.
#   help             Show this message.
#
# This is a thin launcher: it wires the already-validated runtime
# (runtime/py/server.py) and tooling (tools/check_npu.sh) together. It does not
# reimplement any inference logic.
#
# (c) Copyright 2026 Alveare Authors — MIT License.

set -euo pipefail

# Resolve the directory this script lives in (the repo root), following symlinks.
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
ROOT="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"

PY="${ALVEARE_PYTHON:-python}"

usage() {
  cat <<'EOF'
alveare — open NPU LLM runtime for the AMD Ryzen AI (XDNA2) NPU on Linux

USAGE:
    alveare <command> [options]

COMMANDS:
    install               One-command full install (conda env + toolchain + deps).
                          Wraps ./install.sh.
    setup                 Print setup guidance and run lightweight preflight checks.
    check                 Run the NPU smoke test (device node, XRT, conda env,
                          memcpy kernel). Wraps tools/check_npu.sh.
    quantize [alias] <gguf> [--arch A]
                          Convert a source GGUF into Alveare's NPU weight layout.
    build-kernels <model> Compile the hardware NPU kernels (.xclbin) for a model.
    list  (or: models)    List installed models (quantized weight directories).
    serve <model> [opts]  Start the OpenAI-compatible HTTP server for a model.
    chat [opts]           Minimal terminal chat against a running server.
    test                  Run the integration test suite (starts server and chat).
    help                  Show this help.

QUANTIZE:
    alveare quantize [alias] <path-to.gguf> [--arch llama|gemma3|gemma4]

    The model architecture is auto-detected from the GGUF (general.architecture);
    override it with --arch if detection is wrong. The output goes to
    quantized_weights_<alias>, where <alias> defaults to the GGUF's file name.
    Any number of models coexist — each gets its own directory — so you can keep
    e.g. a 12B and a smaller one side by side.

    Examples:
        alveare quantize ~/models/gemma-4-12b-it.gguf       # -> quantized_weights_gemma-4-12b-it
        alveare quantize g4-12b ~/models/gemma-4-12b-it.gguf  # -> quantized_weights_g4-12b
        alveare quantize g4-4b  ~/models/gemma-4-4b-it.gguf   # a second Gemma-4, coexists
        alveare quantize mymodel ./weird.gguf --arch gemma4   # force the architecture
        alveare serve g4-12b

BUILD-KERNELS:
    alveare build-kernels <model>

    Builds the XDNA2 hardware kernels (.xclbin) tailored to the exact matrix 
    shapes of your quantized model. This interrogates the AIE compiler and 
    may take several hours to complete. The kernels will be placed in 
    'kernels/build', which is automatically searched by 'serve'.

    Examples:
        alveare build-kernels gemma4

SERVE:
    <model> resolves in this order: built-in shorthand, then an existing
    directory path, then a generated name (quantized_weights_<model>):

        llama    ->  ./quantized_weights_llama     (Llama-3.2-1B-Instruct)
        gemma3   ->  ./quantized_weights_gemma     (Gemma-3-1B-it)
        gemma4   ->  ./quantized_weights_gemma4    (Gemma-4-12B-it)
        g4-12b   ->  ./quantized_weights_g4-12b     (from `quantize g4-12b ...`)
        <dir>    ->  any directory with a config.json

    Options:
        --host <addr>   Bind address (default 127.0.0.1, or $ALVEARE_HOST).
        --port <port>   Port (default 8000, or $ALVEARE_PORT).
        --offline       Run completely offline (sets HF_HUB_OFFLINE=1).
        --legacy        Run the legacy Python server instead of the Native C++ server.

    Examples:
        alveare serve gemma4
        alveare serve g4-12b --port 9000

CHAT:
    alveare chat [--host H] [--port P] [--model NAME] [--no-stream]
    A tiny REPL that talks to a running server's OpenAI endpoint. Start a
    server first (alveare serve ...), then chat from another terminal.

ENVIRONMENT:
    Run inside the `alveare-aie` conda env with the AIE toolchain sourced.
    See docs/SETUP.md for the full, version-pinned setup.

    ALVEARE_PYTHON   python interpreter to use (default: python)
    ALVEARE_HOST     default serve bind address
    ALVEARE_PORT     default serve port
EOF
}

# Resolve a model name/shorthand/path to a weights directory.
# Resolution order:
#   1. built-in shorthands (llama / gemma3 / gemma4) -> their default dirs
#   2. a directory that exists as-is (an explicit path)
#   3. a generated name <n> -> $ROOT/quantized_weights_<n> (from `alveare quantize ... <n>`)
resolve_weights_dir() {
  local model="$1"
  case "$model" in
    llama|llama-3.2-1b|llama3.2)   echo "$ROOT/quantized_weights_llama" ;;
    gemma3|gemma-3-1b|gemma3-1b)   echo "$ROOT/quantized_weights_gemma" ;;
    gemma4|gemma-4-12b|gemma4-12b) echo "$ROOT/quantized_weights_gemma4" ;;
    *)
      if [ -d "$model" ]; then
        echo "$model"
      else
        echo "$ROOT/quantized_weights_$model"
      fi
      ;;
  esac
}

# Map an architecture keyword to its quantizer script.
resolve_quantizer() {
  case "$1" in
    llama|llama-3.2-1b|llama3.2)   echo "$ROOT/tools/quantize_model.py" ;;
    gemma3|gemma-3-1b|gemma3-1b)   echo "$ROOT/tools/quantize_gemma.py" ;;
    gemma4|gemma-4-12b|gemma4-12b) echo "$ROOT/tools/quantize_gemma4.py" ;;
    *)                             echo "" ;;
  esac
}

cmd_check() {
  exec bash "$ROOT/tools/check_npu.sh" "$@"
}

cmd_setup() {
  echo "=== Alveare setup preflight ==="
  echo "Full, version-pinned instructions: docs/SETUP.md"
  echo
  local ok=1

  if [ -c /dev/accel/accel0 ]; then
    echo "  [ok]   NPU device node /dev/accel/accel0 present"
  else
    echo "  [MISS] NPU device node /dev/accel/accel0 not found"; ok=0
  fi

  if id -nG 2>/dev/null | grep -qw render; then
    echo "  [ok]   user is in the 'render' group"
  else
    echo "  [warn] user not in 'render' group (needed for non-root NPU access)"
  fi

  if command -v xrt-smi >/dev/null 2>&1; then
    echo "  [ok]   xrt-smi found"
  else
    echo "  [MISS] xrt-smi not found (install libxrt-utils-npu)"; ok=0
  fi

  if command -v "$PY" >/dev/null 2>&1; then
    echo "  [ok]   python: $($PY --version 2>&1)"
  else
    echo "  [MISS] python interpreter '$PY' not found"; ok=0
  fi

  if "$PY" -c 'import pyxrt' >/dev/null 2>&1; then
    echo "  [ok]   pyxrt import works"
  else
    echo "  [warn] cannot import pyxrt (activate the alveare-aie conda env)"
  fi

  if "$PY" -c 'import aie' >/dev/null 2>&1; then
    echo "  [ok]   mlir-aie (aie) import works"
  else
    echo "  [warn] cannot import 'aie' (install mlir_aie wheel; see docs/SETUP.md)"
  fi

  if "$PY" -c 'import fastapi, uvicorn, pydantic' >/dev/null 2>&1; then
    echo "  [ok]   server deps (fastapi/uvicorn/pydantic) present"
  else
    echo "  [warn] server deps missing (pip install -r requirements.txt)"
  fi

  echo
  if [ "$ok" -eq 1 ]; then
    echo "Core prerequisites look present. Run 'alveare check' for a full NPU smoke test."
  else
    echo "Some prerequisites are missing — see docs/SETUP.md."
  fi
}

cmd_serve() {
  if [ "$#" -lt 1 ]; then
    echo "error: 'serve' needs a model or weights directory. See 'alveare help'." >&2
    exit 2
  fi
  local model="$1"; shift
  local host="${ALVEARE_HOST:-127.0.0.1}"
  local port="${ALVEARE_PORT:-8000}"
  local offline=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --host) host="$2"; shift 2 ;;
      --port) port="$2"; shift 2 ;;
      --offline) offline=1; shift 1 ;;
      --legacy) legacy=1; shift 1 ;;
      *) echo "error: unknown serve option '$1'" >&2; exit 2 ;;
    esac
  done

  if [ "$offline" -eq 1 ]; then
    export HF_HUB_OFFLINE=1
    echo "Running in offline mode (HF_HUB_OFFLINE=1)"
  fi

  local weights_dir
  weights_dir="$(resolve_weights_dir "$model")"

  if [ ! -d "$weights_dir" ]; then
    echo "error: weights directory not found: $weights_dir" >&2
    echo "Quantize a model first, e.g.:" >&2
    echo "    ./alveare quantize gemma4 /path/to/model.gguf" >&2
    echo "then:  ./alveare serve <name>   (see docs/SETUP.md)" >&2
    exit 1
  fi
  if [ ! -f "$weights_dir/config.json" ]; then
    echo "warning: $weights_dir has no config.json; the server may fail to detect the model." >&2
  fi

  # Preflight: the server needs its runtime deps AND the NPU stack. The #1
  # gotcha is running from the wrong env (e.g. conda 'base'), where these are
  # missing. Fail early with an actionable message instead of a raw traceback.
  local missing=""
  "$PY" -c 'import fastapi, uvicorn, pydantic' >/dev/null 2>&1 || missing="$missing fastapi/uvicorn/pydantic"
  "$PY" -c 'import pyxrt' >/dev/null 2>&1 || missing="$missing pyxrt(NPU)"
  if [ -n "$missing" ]; then
    echo "error: missing Python dependencies for '$PY':$missing" >&2
    echo >&2
    echo "You are probably not in the 'alveare-aie' conda environment." >&2
    echo "Activate it and install the runtime deps, then retry:" >&2
    echo "    conda activate alveare-aie" >&2
    echo "    pip install -r requirements.txt          # fastapi, uvicorn, ..." >&2
    echo "    cd mlir-aie && source utils/env_setup.sh  # NPU stack (pyxrt/aie)" >&2
    echo "See docs/SETUP.md for the full, version-pinned setup." >&2
    exit 1
  fi

  echo "Serving model from: $weights_dir"
  echo "OpenAI-compatible endpoint: http://$host:$port/v1"
  echo "  GET  /v1/models"
  echo "  POST /v1/chat/completions"
  echo

  export ALVEARE_WEIGHTS_DIR="$weights_dir"
  export ALVEARE_HOST="$host"
  export ALVEARE_PORT="$port"
  
  if [ "${legacy:-0}" -eq 1 ]; then
    echo "Starting Legacy Python Server..."
    exec "$PY" "$ROOT/runtime/py/server.py"
  else
    echo "Starting Native C++ Server..."
    local manifest="$ROOT/kernels/build/manifest.json"
    if [ ! -f "$manifest" ]; then
      echo "error: manifest not found at $manifest. Ensure kernels are built." >&2
      exit 1
    fi
    exec "$ROOT/runtime/cpp/build/alveare_runtime" "$weights_dir" "$manifest" "$port"
  fi
}

cmd_install() {
  if [ ! -x "$ROOT/install.sh" ]; then
    echo "error: install.sh not found or not executable at $ROOT/install.sh" >&2
    exit 1
  fi
  exec bash "$ROOT/install.sh" "$@"
}

cmd_build_kernels() {
  if [ "$#" -lt 1 ]; then
    echo "error: 'build-kernels' needs a model or weights directory. See 'alveare help'." >&2
    exit 2
  fi
  local model="$1"; shift
  local weights_dir
  weights_dir="$(resolve_weights_dir "$model")"

  if [ ! -d "$weights_dir" ]; then
    echo "error: weights directory not found: $weights_dir" >&2
    exit 1
  fi

  local out_dir="$ROOT/kernels/build"
  mkdir -p "$out_dir"
  echo "Building hardware kernels for $weights_dir"
  echo "Output directory: $out_dir"
  echo "NOTE: This interrogates the XDNA2 compiler and can take a long time."
  echo "----------------------------------------------------------------------"
  exec "$PY" "$ROOT/tools/build_kernels.py" --weights-dir "$weights_dir" --out "$out_dir" "$@"
}

cmd_quantize() {
  # Usage:
  #   alveare quantize <gguf> [--arch A]           name defaults to the GGUF filename
  #   alveare quantize <alias> <gguf> [--arch A]   explicit output name (alias)
  local arch="" positionals=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --arch) arch="$2"; shift 2 ;;
      --arch=*) arch="${1#--arch=}"; shift ;;
      -*) echo "error: unknown quantize option '$1'" >&2; exit 2 ;;
      *) positionals+=("$1"); shift ;;
    esac
  done

  local gguf alias
  case "${#positionals[@]}" in
    1) gguf="${positionals[0]}"; alias="" ;;
    2) alias="${positionals[0]}"; gguf="${positionals[1]}" ;;
    *)
      echo "error: usage: alveare quantize [alias] <path-to.gguf> [--arch llama|gemma3|gemma4]" >&2
      exit 2 ;;
  esac

  if [ ! -f "$gguf" ]; then
    echo "error: GGUF file not found: $gguf" >&2
    exit 1
  fi

  # Output name (alias): default to the GGUF's base filename (without .gguf).
  if [ -z "$alias" ]; then
    alias="$(basename "$gguf")"; alias="${alias%.gguf}"
  fi

  # Architecture: explicit --arch wins; otherwise auto-detect from the GGUF.
  if [ -z "$arch" ]; then
    arch="$("$PY" "$ROOT/tools/detect_arch.py" "$gguf")" || {
      echo "hint: force it with --arch llama|gemma3|gemma4 if detection is wrong." >&2
      exit 1
    }
    echo "Detected architecture: $arch"
  fi

  local quantizer
  quantizer="$(resolve_quantizer "$arch")"
  if [ -z "$quantizer" ]; then
    echo "error: unknown arch '$arch' (expected: llama, gemma3, gemma4)" >&2
    exit 2
  fi

  local out_dir="$ROOT/quantized_weights_$alias"
  echo "Quantizing ($arch): $gguf"
  echo "  -> $out_dir"
  echo "  then serve with:  ./alveare serve $alias"
  echo
  exec "$PY" "$quantizer" "$gguf" --out "$out_dir"
}

cmd_list() {
  echo "Installed models (quantized weight directories):"
  local found=0
  local d name mt cfg size
  for d in "$ROOT"/quantized_weights_*; do
    [ -d "$d" ] || continue
    found=1
    name="$(basename "$d")"; name="${name#quantized_weights_}"
    cfg="$d/config.json"
    if [ -f "$cfg" ]; then
      mt="$("$PY" -c "import json,sys;print(json.load(open('$cfg')).get('model_type','?'))" 2>/dev/null || echo '?')"
    else
      mt="llama (no config.json)"
    fi
    size="$(du -sh "$d" 2>/dev/null | cut -f1)"
    printf "  %-24s  arch=%-8s  %6s   (serve: ./alveare serve %s)\n" "$name" "$mt" "$size" "$name"
  done
  [ "$found" -eq 1 ] || echo "  (none yet — run: ./alveare quantize <alias> <model.gguf>)"
}

cmd_chat() {
  exec "$PY" "$ROOT/tools/chat.py" "$@"
}

cmd_test() {
  exec "$PY" "$ROOT/tests/integration/test_server.py" "$@"
}

main() {
  local cmd="${1:-help}"
  [ "$#" -gt 0 ] && shift || true
  case "$cmd" in
    install)      cmd_install "$@" ;;
    setup)        cmd_setup "$@" ;;
    check)        cmd_check "$@" ;;
    build-kernels)cmd_build_kernels "$@" ;;
    quantize)     cmd_quantize "$@" ;;
    list|models)  cmd_list "$@" ;;
    serve)        cmd_serve "$@" ;;
    chat)         cmd_chat "$@" ;;
    test)         cmd_test "$@" ;;
    help|-h|--help) usage ;;
    *) echo "error: unknown command '$cmd'" >&2; echo >&2; usage >&2; exit 2 ;;
  esac
}

main "$@"
